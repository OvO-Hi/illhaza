# ─── Database ─────────────────────────
# Neon Postgres — pooled connection (애플리케이션에서 사용)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Neon Postgres — direct connection (마이그레이션 전용)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# ─── 암호화 ─────────────────────────
# AES-256-GCM 키 (32바이트 base64)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# ─── 이메일 발송 (Resend) ─────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── 네이버 지역 검색 (Naver Developers) ─────────────────────────
# 서버 사이드 — 장소 키워드 검색
NAVER_SEARCH_CLIENT_ID=""
NAVER_SEARCH_CLIENT_SECRET=""

# ─── 네이버 지도 SDK (Naver Cloud Platform) ─────────────────────────
# 클라이언트 사이드 — Maps Web Dynamic Map (브라우저에 노출됨)
NEXT_PUBLIC_NCP_MAP_CLIENT_ID=""
# 서버 사이드 — Geocoding API (수동 등록 시 주소 → 좌표 변환)
NCP_MAP_CLIENT_SECRET=""

# ─── ODsay (대중교통 길찾기, Fly.io 프록시 경유) ─────────────────────────
# Vercel은 동적 outbound IP라 ODsay 화이트리스트를 통과 못 함.
# 고정 IP를 가진 프록시 서버를 거쳐 호출.
ODSAY_PROXY_URL="https://illhaza-odsay-proxy.fly.dev"
ODSAY_PROXY_SECRET=""

# (구) ODsay 직접 호출용 — 더 이상 사용하지 않음
# ODSAY_API_KEY=""

# ─── Anthropic (어드민 OCR) ─────────────────────────
ANTHROPIC_API_KEY=""

# ─── 기준 좌표 (이화여대) ─────────────────────────
EWHA_MAIN_GATE_LAT="37.5615"
EWHA_MAIN_GATE_LNG="126.9469"
EWHA_BACK_GATE_LAT="37.5667"
EWHA_BACK_GATE_LNG="126.9466"

# ─── 어드민 ─────────────────────────
# 시드된 어드민 이메일의 SHA-256 해시 (콤마 구분, 시드 후 채움)
ADMIN_EMAIL_HASHES=""

# 시드 스크립트가 어드민으로 등록할 이메일 (콤마 구분)
# 예: SEED_ADMIN_EMAILS="admin1@ewha.ac.kr,admin2@ewhain.net"
SEED_ADMIN_EMAILS=""

# ─── 앱 ─────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
